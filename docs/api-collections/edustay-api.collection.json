  "item": [
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Demo\",\n  \"apellido\": \"Usuario\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\",\n  \"telefono\": \"999999999\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login (captura JWT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "if (data.token) { pm.environment.set('jwt', data.token); }",
                  "pm.test('JWT guardado en variable jwt', function () {",
                  "  pm.expect(pm.environment.get('jwt')).to.not.be.oneOf([null, '']);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login con Google",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tokenId\": \"GOOGLE_ID_TOKEN_AQUI\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "google"]
            }
          }
        },
        {
          "name": "Validate token",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/validate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "validate"]
            }
          }
        }
      ]
    },
